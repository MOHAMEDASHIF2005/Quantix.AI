# Database
DATABASE_URL=sqlite:///./quantix.db

# App
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
PROJECT_NAME=Quantix AI

# Optional: enable LLM-generated narrative insights.
# If unset, the platform still runs on its own deterministic
# explainability engine (no external calls required).
ANTHROPIC_API_KEY=
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
